{
  "_comment": "TEMPLATE — copy to ~/.claude/settings.local.json on a new machine, then let Claude Code grow the allow-list as you approve permissions. Do NOT symlink this and do NOT commit the real settings.local.json (it accumulates machine-specific rules and may capture tokens).",

  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Read(/tmp/**)",
      "Bash(git --version)",
      "Bash(git clone *)",
      "Bash(git pull *)",
      "Bash(gh repo *)",
      "Bash(gh api *)",
      "Bash(brew install *)",
      "Bash(npm install *)",
      "Bash(npm run *)",
      "Bash(bun --version)",
      "Bash(curl -fsSL https://bun.sh/install)",
      "Bash(mkdir -p ~/.claude/skills/*)",
      "Write(~/.claude/skills/*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo rm *)",
      "Bash(curl * | bash)",
      "Bash(wget * | bash)",
      "Bash(chmod 777 *)",
      "Bash(sudo chmod *)",
      "Bash(dd if=*)",
      "Bash(mkfs*)",
      "Bash(sudo *)"
    ]
  }
}
