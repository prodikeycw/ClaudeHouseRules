{
  "language": "chinese",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/protect-main.sh",
            "if": "Bash(git push*)",
            "statusMessage": "检查分支保护..."
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/secret-scan.sh",
            "if": "Bash(git commit*)",
            "statusMessage": "扫描密钥..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/lang-reminder.sh"
          }
        ]
      }
    ]
  }
}
